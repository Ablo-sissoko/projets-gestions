{
  "expo": {
    "name": "Deegipos",
    "slug": "deegipos",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/1024x1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/img_background_app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "versionCode": 7,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/1024x1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.famakan.deegipos",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/1024x1024.png"
    },
    "extra": {
      "eas": {
        "projectId": "60c17ea9-7134-4cc6-8bfb-aa13e164f523"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'application a besoin d'accéder à la caméra pour scanner les codes-barres."
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "fb",
            "instagram",
            "twitter",
            "tiktoksharesdk"
          ],
          "android": [
            "com.facebook.katana",
            "com.instagram.android",
            "com.twitter.android",
            "com.zhiliaoapp.musically"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "./plugins/withMlKitBarcodeOrientation"
    ],
    "owner": "famayou"
  }
}
