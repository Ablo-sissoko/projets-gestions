{
  "expo": {
    "name": "DEEGIPOS",
    "slug": "DEEGIPOS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/10124x1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/img_background_app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/10124x1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.famakan.DEEGIPOS",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/10124x1024.png"
    },
    "extra": {
      "eas": {
        "projectId": "171f023e-7c05-4935-9822-cc3c82b014b9"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos."
        }
      ]
    ],
    "owner": "famayou"
  }
}
